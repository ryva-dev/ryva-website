APP_URL=http://localhost:5173
NODE_ENV=development
DATABASE_PATH=./data/app.db
STORAGE_ROOT=./data
# Phase 2 (Postgres). When set, the app uses Postgres instead of SQLite.
# Example: postgres://user:pass@host:5432/ryva
DATABASE_URL=
# verify-full (default) verifies the chain; require keeps TLS but accepts provider-managed/self-signed chains (Railway); disable is local-only.
PGSSL=
PG_POOL_MAX=10
ADMIN_EMAILS=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Server-side public YouTube niche research; results are cached to protect quota.
YOUTUBE_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_INTERVIEW_MODEL=claude-sonnet-4-6
ANTHROPIC_ONBOARDING_MODEL=claude-sonnet-4-6
ANTHROPIC_OFFICE_MODEL=claude-sonnet-4-6
ANTHROPIC_MEMORY_MODEL=claude-sonnet-4-6
ANTHROPIC_MARA_INBOX_MODEL=claude-sonnet-4-6
ANTHROPIC_AGENT_MODEL=claude-sonnet-4-6
MARA_INBOX_PARSE_LIMIT_PER_SYNC=5
MARA_TREND_SNAPSHOT_MAX_AGE_HOURS=168
# Background autonomy scheduler cadence (minutes); 0 disables it.
MARA_AUTONOMY_INTERVAL_MINUTES=15
# Required explicitly in production: 1 on designated scheduler/worker replicas, 0 on web-only replicas.
AUTONOMY_SCHEDULER_ENABLED=1
# Brand research / deep research / outreach draft budgets (backend enforced).
MARA_DAILY_BRAND_RESEARCH_LIMIT=5
MARA_WEEKLY_DEEP_RESEARCH_LIMIT=20
MARA_WEEKLY_OUTREACH_DRAFT_LIMIT=25
# Social research providers (optional). Creators never supply provider keys or trend dumps.
# Without these, Mara uses public Reddit evidence and omits unverified platform claims.
# X_BEARER_TOKEN=
# META_ACCESS_TOKEN=
# FACEBOOK_ACCESS_TOKEN=
# IG_USER_ID=
# TIKTOK_ACCESS_TOKEN=
# TIKTOK_ADVERTISER_ID=
# Operator-managed JSON/HTML feed from a licensed TikTok trend collector (Apify, Bright Data, etc.).
# TIKTOK_TRENDS_FEED_URL=
# TIKTOK_TRENDS_FEED_TOKEN=
# Contact enrichment (optional paid). Free site probes always run.
# HUNTER_API_KEY=
# APOLLO_API_KEY=
# MARA_PRIVATE_INSIGHTS_PATH=
# Video analysis limits and providers (mock by default in development).
MARA_VIDEO_MAX_BYTES=83886080
MARA_VIDEO_MAX_DURATION_SECONDS=180
MARA_TRANSCRIPTION_PROVIDER=mock
MARA_MULTIMODAL_PROVIDER=mock
# Production: either enable real providers OR disable video QA.
# MARA_DISABLE_VIDEO_QA=1
# Real creative QA path (required in production unless MARA_DISABLE_VIDEO_QA=1):
# MARA_TRANSCRIPTION_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_WHISPER_MODEL=whisper-1
# MARA_MULTIMODAL_PROVIDER=anthropic
# MARA_MULTIMODAL_MODEL=claude-sonnet-4-20250514
# Refuse mock media analysis:
# MARA_REQUIRE_REAL_MEDIA=1
# MARA_MEDIA_SCANNER=noop
# Support contact shown on legal pages:
# SUPPORT_EMAIL=support@yourdomain.com
# Optional Stripe Price IDs (recommended for receipts). Falls back to inline price_data.
# STRIPE_PRICE_ID_MARA_VALE=price_...
# STRIPE_PRICE_ID=price_...
# Per-user daily cap on LLM calls across all workers (cost guard).
AGENT_DAILY_LLM_CALL_LIMIT=300
# SESSION_SECRET is unused (DB cookie sessions). Kept here only so old .env files don't confuse operators.
# SESSION_SECRET=
# Encryption key for OAuth tokens at rest (AES-256). 64 hex chars or base64 -> 32 bytes.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Customer file storage. Use S3 in production; local is for development only.
OBJECT_STORAGE_DRIVER=local
# S3_BUCKET=
# AWS_REGION=us-east-1
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=false
# S3_SERVER_SIDE_ENCRYPTION=AES256
# Protect GET /metrics (required effectively in production — endpoint 401s without it).
# METRICS_TOKEN=
# Migrate before listen when DATABASE_URL is set (default 1). Set 0 for init-container-only.
# MIGRATE_ON_BOOT=1
# Optional error tracking (@sentry/node is a real dependency; activates when DSN is set):
# SENTRY_DSN=
LOG_LEVEL=info
# Business Pain Intelligence. Live Reddit is hard-disabled unless explicit approval is recorded.
PAIN_INTEL_HASH_SALT=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=
REDDIT_ACCESS_APPROVED=false
# Configurable, comma-separated phase-one scope (no communities are hard-coded in the connector).
REDDIT_COMMUNITIES=smallbusiness,Entrepreneur,startups,SaaS,ecommerce,shopify,marketing,digital_marketing,agency,freelancing,consulting,sales,EntrepreneurRideAlong
# Official Hacker News API. Set to 1 on exactly one local/server process for scheduled collection.
PAIN_INTEL_HN_AUTOMATION_ENABLED=0
PAIN_INTEL_HN_INTERVAL_MINUTES=360
PAIN_INTEL_HN_STORY_LIMIT=200
PAIN_INTEL_HN_COMMENT_LIMIT=1200
# Mara V2/V3 runtime. Defaults are off and shadow-only until explicitly enabled.
MARA_EVENTS_V2=0
MARA_STATE_V2_WRITE=0
MARA_CANDIDATES_V2=0
MARA_SHADOW_PLANNER=0
MARA_PLAYBOOKS_V1=0
MARA_MODEL_USAGE_V1=0
MARA_TASK_GRAPH_V1=0
MARA_DETERMINISTIC_SCHEDULING_V1=0
MARA_CONTROLLED_INTERNAL_EXECUTION_V1=0
MARA_REASSESSMENT_V1=0
MARA_BRIEFINGS_V2=0
MARA_RUNTIME_V2_MODE=shadow
# Comma-separated internal tenant IDs; required in addition to controlled_execution mode.
MARA_CONTROLLED_EXECUTION_USER_IDS=
MARA_OPPORTUNITY_PAUSE_THRESHOLD=20
MARA_OPPORTUNITY_RESUME_THRESHOLD=14
MARA_DORMANT_IGNORED_TASK_THRESHOLD=5
MARA_SHADOW_MAX_PLAN_COST_USD=0.15
# Provider pricing inputs for estimated usage accounting; recalibrate when pricing changes.
MODEL_INPUT_USD_PER_MILLION=3
MODEL_OUTPUT_USD_PER_MILLION=15
MODEL_CACHED_INPUT_USD_PER_MILLION=0.3
OPENAI_WHISPER_USD_PER_MINUTE=0.006
