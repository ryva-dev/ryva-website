APP_URL=http://localhost:5173
NODE_ENV=development
DATABASE_PATH=./data/app.db
STORAGE_ROOT=./data
# Phase 2 (Postgres). When set, the app uses Postgres instead of SQLite.
# Example: postgres://user:pass@host:5432/ryva
DATABASE_URL=
# Set PGSSL=disable for a local Postgres without TLS. Managed hosts (RDS/Aurora) keep SSL on.
PGSSL=
PG_POOL_MAX=10
ADMIN_EMAILS=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_INTERVIEW_MODEL=claude-sonnet-4-6
ANTHROPIC_ONBOARDING_MODEL=claude-sonnet-4-6
ANTHROPIC_OFFICE_MODEL=claude-sonnet-4-6
ANTHROPIC_MEMORY_MODEL=claude-sonnet-4-6
ANTHROPIC_MARA_INBOX_MODEL=claude-sonnet-4-6
ANTHROPIC_AGENT_MODEL=claude-sonnet-4-6
MARA_INBOX_PARSE_LIMIT_PER_SYNC=5
MARA_TREND_SNAPSHOT_MAX_AGE_HOURS=168
# Background autonomy scheduler cadence (minutes); 0 disables it.
MARA_AUTONOMY_INTERVAL_MINUTES=15
# Per-user daily cap on LLM calls across all workers (cost guard).
AGENT_DAILY_LLM_CALL_LIMIT=300
SESSION_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
