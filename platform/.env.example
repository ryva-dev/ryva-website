NODE_ENV=development
APP_URL=http://127.0.0.1:5173
PORT=8787
DATABASE_URL=postgres://localhost/ryva_pro_dev
PGSSL=disable
PG_POOL_MAX=10
LOG_LEVEL=info

# Generate with: openssl rand -hex 32
SESSION_PEPPER=
FIELD_ENCRYPTION_KEY=
SESSION_TTL_HOURS=168
TRUST_PROXY=0

# Credential provider. Production requires a signed webhook secret and may
# optionally use a provider API for user-initiated refresh.
CREDENTIAL_WEBHOOK_SECRET=
CREDENTIAL_API_URL=
CREDENTIAL_API_TOKEN=

# Optional external intelligence source. Returned candidates must still be
# recorded with provenance and accepted by a human; provider data never qualifies a record.
INTELLIGENCE_API_URL=
INTELLIGENCE_API_TOKEN=

# Evidence-first AI copilot. Core workflows remain manual when disabled.
# The provider must accept schema-constrained requests and must not receive tools.
AI_PROVIDER_URL=
AI_PROVIDER_TOKEN=
AI_MODEL=provider-default
AI_MODEL_VERSION=unknown
AI_GENERATION_ENABLED=0
AI_PROVIDER_RETENTION_MODE=zero_data_retention
AI_ALLOW_PROVIDER_TRAINING=0
AI_TIMEOUT_MS=30000
AI_MAX_CONTEXT_ITEMS=50

# Transactional email. External sends remain disabled unless the adapter,
# signed webhook, verified sender, and worker are all configured.
EMAIL_PROVIDER_URL=
EMAIL_PROVIDER_TOKEN=
EMAIL_WEBHOOK_SECRET=
EMAIL_FROM_ADDRESS=
OUTREACH_SEND_ENABLED=0

# Billing provider. Production requires all three Stripe values.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Documents. Production requires S3 and a signed malware-scanner callback.
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=.data/documents
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
MALWARE_SCANNER_WEBHOOK_SECRET=

# Operations
SUPPORT_EMAIL=support@example.com
JOB_WORKER_ENABLED=0
CONTROLLED_LAUNCH_ENABLED=0
JOB_POLL_INTERVAL_MS=5000
RATE_LIMIT_WINDOW_SECONDS=600
RATE_LIMIT_LOGIN_MAX=10

# Synthetic-only local setup. Never enable in production.
ALLOW_SYNTHETIC_SEED=1
